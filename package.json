{
  "name": "zoteroseek",
  "version": "0.1.0",
  "description": "AI-powered research assistant for Zotero",
  "config": {
    "addonName": "ZoteroSeek",
    "addonID": "zoteroseek@kingcrimsonwww.github.io",
    "addonRef": "zoteroseek",
    "addonInstance": "ZoteroSeek",
    "prefsPrefix": "extensions.zotero.zoteroseek",
    "releasePage": "https://github.com/KingCrimsonWWW/ZoteroSeek/releases",
    "updaterdf": "https://raw.githubusercontent.com/KingCrimsonWWW/ZoteroSeek/main/update.json"
  },
  "main": "src/index.ts",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "tsc --noEmit && zotero-plugin build",
    "build-dev": "cross-env NODE_ENV=development zotero-plugin build",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "typecheck": "tsc --noEmit",
    "release": "zotero-plugin release",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KingCrimsonWWW/ZoteroSeek.git"
  },
  "author": "KingCrimsonWWW",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/KingCrimsonWWW/ZoteroSeek/issues"
  },
  "homepage": "https://github.com/KingCrimsonWWW/ZoteroSeek#readme",
  "dependencies": {
    "@heroicons/react": "^2.1.3",
    "dexie": "^4.0.10",
    "langchain": "^0.3.0",
    "lodash": "^4.17.21",
    "marked": "^12.0.0",
    "marked-react": "^2.0.0",
    "openai": "^4.79.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-syntax-highlighter": "^15.6.1",
    "zod": "^3.23.8",
    "zotero-plugin-toolkit": "^4.1.1"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.19",
    "compressing": "^1.10.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "esbuild": "^0.21.0",
    "esbuild-style-plugin": "^1.6.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "postcss": "^8.4.49",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "release-it": "^17.6.0",
    "replace-in-file": "^7.2.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.5.0",
    "zotero-plugin-scaffold": "^0.1.7",
    "zotero-types": "^3.0.1"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "bracketSpacing": true,
    "arrowParens": "always",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  }
}
