<?xml version="1.0" encoding="UTF-8"?>
<RDF xmlns="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:em="http://www.mozilla.org/2004/em-rdf#">

  <Description about="urn:mozilla:install-manifest">
    <em:id>zoteroseek@kingcrimsonwww.github.io</em:id>
    <em:name>ZoteroSeek</em:name>
    <em:version>0.1.0</em:version>
    <em:type>2</em:type>
    <em:bootstrap>true</em:bootstrap>

    <em:targetApplication>
      <Description>
        <!-- Zotero -->
        <em:id>zotero@chnm.gmu.edu</em:id>
        <em:minVersion>9.0.0</em:minVersion>
        <em:maxVersion>*</em:maxVersion>
      </Description>
    </em:targetApplication>

    <em:creator>KingCrimsonWWW</em:creator>
    <em:description>AI-powered research assistant for Zotero</em:description>
    <em:homepageURL>https://github.com/KingCrimsonWWW/ZoteroSeek</em:homepageURL>
  </Description>
</RDF>
